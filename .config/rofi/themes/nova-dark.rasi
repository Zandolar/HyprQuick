/* config - Launcher */

/* ---- Configuration ---- */

configuration {
	modi:                       "drun,run,filebrowser,window,calc";
    show-icons:                 true;
    display-calc:               "Calc";
    display-drun:               "Apps";
    display-run:                "Run";
    display-filebrowser:        "Files";
    display-window:             "Windows";
	drun-display-format:        "{name}";
	window-format:              "{w} · {c} · {t}";
    font:                        "CaskaydiaCove Nerd Font Propo Bold 11";
}

/* ---- Load matugen colors ---- */
@theme "~/.config/rofi/colors.rasi"

/* ---- Global Properties ---- */
* {

    background-alt:              @surface-container-highest; // Buttons background
    selected:                    @on-primary; // Button selected
    active:                      @secondary-container; // Window activated
    urgent:                      @on-error; // When hovering the activated window (maybe more?)

    text-selected:               @on-tertiary-fixed-variant;
    text-color:                  @secondary;
    border-color:                @outline-variant;
}

/* ---- Window ---- */
window {
    // Default
    enabled:                    true;
    fullscreen:                 false;
    transparency:               "real";
    cursor:                     "default";
    spacing:                    0px;
    border:                     2px;
    border-radius:              30px;
    location:                   center;
    anchor:                     center;

    // Style Values
    width:                      55%;
    background-color:           @surface-container-highest;
}

/* ----- Main Box ----- */
mainbox {
    enabled:                     true;
    orientation:                 vertical;
    children:                    [ "inputbar", "listbox" ];
    background-color:            transparent;
}


/* ---- Inputbar ---- */
inputbar {
    enabled:                     true;
    padding:                     80px 60px;
    margin:                      20px;
    background-color:            transparent;
    border-radius:               25px;
    orientation:                 horizontal;
    children:                    ["entry", "dummy", "mode-switcher" ];
    background-image:            url("~/.cache/.current_wallpaper", width);
}

/* ---- Entry input ---- */
entry {
    enabled:                     true;
    expand:                      false;
    width:                       300px;
    padding:                     12px 16px;
    border-radius:               10px;
    background-color:            @on-secondary-fixed;
    text-color:                  inherit;
    cursor:                      text;
    placeholder:                 "  Search"; // << Search symbol
    placeholder-color:           inherit;
}

/* ---- Listbox ---- */
listbox {
    spacing:                     20px;
    padding:                     20px;
    background-color:            transparent;
    orientation:                 vertical;
    children:                    [ "message", "listview" ];
}

/* ---- Listview ---- */
listview {
    enabled:                     true;
    columns:                     2;
    lines:                       8;
    cycle:                       true;
    dynamic:                     true;
    scrollbar:                   false;
    layout:                      vertical;
    reverse:                     false;
    fixed-height:                true;
    fixed-columns:               true;
    
    spacing:                     10px;
    background-color:            transparent;

//  Adapt rofi theme
    border:                      0px;
}

/* ---- Dummy ---- */
dummy {
    expand:                      true;
    background-color:            transparent;
}

/* ---- Mode Switcher ---- */
mode-switcher{
    enabled:                     true;
    spacing:                     10px;
    background-color:            transparent;
}
button {
    width:                       90px;
    padding:                     12px;
    border-radius:               12px;
    background-color:            @secondary-container;
    text-color:                  inherit;
    cursor:                      pointer;
}
button selected {
    background-color:            @secondary-fixed-dim;
    text-color:                  @on-secondary-fixed;
}


/* ---- Elements ---- */
element {
    enabled:                     true;
    spacing:                     10px;
    padding:                     4px;
    border-radius:               10px;
    background-color:            transparent;
    cursor:                      pointer;
}


element normal.normal {
    background-color:            inherit;
    text-color:                  inherit;
}
element normal.urgent {
    background-color:            @on-error;
    text-color:                  @primary-fixed;
}
element normal.active {
    background-color:            @surface-bright;
    text-color:                  @primary-fixed;
}

element selected.normal {
    background-color:            @secondary-fixed;
    text-color:                  @on-secondary-fixed;
}
element selected.urgent {
    background-color:            @on-error;
    text-color:                  @inverse-surface;
}
element selected.active {
    background-color:            @on-error;
    text-color:                  @inverse-surface;
}
// Adapt rofi theme
element alternate.normal {
    background-color:            transparent;
    text-color:                  inherit;
}
element alternate.urgent {
    background-color:            transparent;
    text-color:                  inherit;
}
element alternate.active {
    background-color:            transparent;
    text-color:                  inherit;
}
element-icon {
    background-color:            transparent;
    text-color:                  inherit;
    size:                        36px;
    cursor:                      inherit;
}
element-text {
    background-color:            transparent;
    text-color:                  inherit;
    cursor:                      inherit;
    vertical-align:              0.5;
    horizontal-align:            0.0;

}

/* ---- Message ---- */
message {
    background-color:            transparent;
    border:                      0px;
}
textbox {
    padding:                     12px;
    border-radius:               10px;
    background-color:            @on-tertiary-fixed;
    text-color:                  @primary-fixed;
    vertical-align:              0.5;
    horizontal-align:            0.0;
}
error-message {
    padding:                     12px;
    border-radius:               20px;
    background-color:            @on-error;
    text-color:                  @error;
}
